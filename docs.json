{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "OpenCompany",
  "colors": {
    "primary": "#BD93F9",
    "light": "#FF79C6",
    "dark": "#6272A4"
  },
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "modeToggle": {
    "default": "dark"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Get Started",
        "icon": "rocket",
        "groups": [
          {
            "group": "Start here",
            "icon": "flag",
            "pages": ["introduction", "how-it-works", "choose-how-to-run"]
          },
          {
            "group": "Set it up",
            "icon": "download",
            "pages": ["installation", "add-api-keys", "first-chat"]
          },
          {
            "group": "Build your first workflow",
            "icon": "diagram-project",
            "pages": ["quickstart"]
          },
          {
            "group": "When something breaks",
            "icon": "life-ring",
            "pages": ["troubleshooting", "faq"]
          }
        ]
      },
      {
        "tab": "Guides",
        "icon": "map",
        "groups": [
          {
            "group": "Tutorials",
            "icon": "graduation-cap",
            "pages": [
              "tutorials/first-workflow",
              "tutorials/telegram-bot",
              "tutorials/ai-agent-workflow",
              "tutorials/whatsapp-automation",
              "tutorials/android-automation"
            ]
          },
          {
            "group": "Deploy",
            "icon": "cloud-arrow-up",
            "pages": ["deployment/production"]
          }
        ]
      },
      {
        "tab": "Reference",
        "icon": "book",
        "groups": [
          {
            "group": "Concepts",
            "icon": "lightbulb",
            "pages": ["architecture", "canvas", "credentials"]
          },
          {
            "group": "Node catalog",
            "icon": "cubes",
            "pages": [
              "nodes/overview",
              {
                "group": "AI",
                "icon": "brain",
                "pages": ["nodes/ai-models", "nodes/ai-agent", "nodes/skills", "nodes/tools"]
              },
              {
                "group": "Integrations",
                "icon": "plug",
                "pages": [
                  "nodes/google-workspace",
                  "nodes/email",
                  "nodes/messaging",
                  "nodes/whatsapp",
                  "nodes/stripe",
                  "nodes/android"
                ]
              },
              {
                "group": "Web & Data",
                "icon": "globe",
                "pages": [
                  "nodes/search",
                  "nodes/browser",
                  "nodes/scraping",
                  "nodes/documents",
                  "nodes/webhooks"
                ]
              },
              {
                "group": "Code & System",
                "icon": "terminal",
                "pages": ["nodes/code", "nodes/filesystem", "nodes/schedulers"]
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/zeenie-ai/opencompany"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://docs.zeenie.xyz/installation"
    }
  },
  "footerSocials": {
    "github": "https://github.com/zeenie-ai/opencompany"
  },
  "feedback": {
    "thumbsRating": true
  },
  "search": {
    "prompt": "Search OpenCompany docs..."
  },
  "styling": {
    "codeBlock": {
      "theme": {
        "dark": "dracula",
        "light": "github-light"
      }
    }
  }
}
